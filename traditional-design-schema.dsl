// ============================================================
// Nablarch 開発標準・設計ドキュメント スキーマ
// ------------------------------------------------------------
// 出典: nablarch-development-standards/030_設計ドキュメント
//   ・010_フォーマット 配下の全 Excel/Word テンプレート
//   ・020_サンプル 配下の全 Excel 記入例
//   ・Nablarch開発標準設計書一覧.xlsx（体系図／一覧／実装対応）
// 記法: ドメイン記述ミニ言語（kawasima/Scrapbox）
//   data 名前 = 構造  / behavior 名前 = 入力 -> 出力
//   AND 全部必要 / OR どれか1つ / List<...> 複数 / ? 任意
//   // コメントで自然言語の制約を補足
//
// 設計方針:
//   ・カラム1個まで欠落させない。1セル＝1 data。
//   ・列挙値（処理方式・媒体など）はサンプルから観測された値を OR で列挙し、
//     拡張余地は「OR その他」を付ける。
//   ・「○ / − / 空」のフラグ列は「指定有 OR 指定無」の2値型に正規化。
//   ・単純なID／名称はすべて単純値として最下層まで分解。
//   ・状態（「未承認 → 承認済」のような）は OR で列挙し behavior で遷移。
// ============================================================


// ============================================================
// §0. 共通の基本値（複数の設計書から参照される最下層の単純値）
// ============================================================

// PJ全体で一意なID群
// 1〜10桁の英数字。サブシステムIDから派生して構成されることが多い
data サブシステムID = 文字列
data サブシステム名 = 文字列    // 1〜100文字
data システム名     = 文字列    // 1〜100文字
data PJ名           = 文字列

// 機能ID（取引より上位の機能の識別子）
data 機能ID  = 文字列            // 例: 11AA
data 機能名  = 文字列
data 機能説明 = 文字列

// 取引ID（1機能の中で行われる業務単位）
data 取引ID  = 文字列            // 例: W11AA0301, A42AA02, B42AA010, M21AA01
data 取引名  = 文字列
data 取引概要 = 文字列
data 想定利用ユーザ = 文字列?
data 前提事項 = 文字列?

// リクエスト（処理依頼イベント）の識別子
data リクエストID = 文字列
data リクエスト名 = 文字列
data リクエスト説明 = 文字列

// 共通コンポーネント
data 共通コンポーネントID = 文字列
data 共通コンポーネント名 = 文字列
data クラス名     = 文字列      // FQCN
data メソッド名   = 文字列
data 処理名       = 文字列
data 処理概要     = 文字列
data 処理説明     = 文字列

// 画面
data 画面ID = 文字列
data 画面名 = 文字列
data 画面説明 = 文字列

// 帳票
data 帳票ID = 文字列
data 帳票名 = 文字列
data 帳票概要 = 文字列

// メール
data メールID = 文字列
data メール名 = 文字列
data メール概要 = 文字列
data メールテンプレートID = 文字列
data メールテンプレート名 = 文字列

// メッセージ（業務メッセージ＝多言語対応のメッセージ文言）
data メッセージID = 文字列
data メッセージ内容 = 文字列
data 埋め込み文字列 = 文字列    // {0}, {1} のような置換変数

// コード
data コードID    = 文字列        // 例: C1100001
data コード名称  = 文字列
data コード説明  = 文字列
data コード値    = 文字列
data コード名    = 文字列
data コード略称  = 文字列?
data ソート順    = 整数

// テーブル／カラム
data 物理テーブル名 = 文字列    // DB物理名
data 論理テーブル名 = 文字列
data テーブル説明   = 文字列
data 物理カラム名   = 文字列
data 論理カラム名   = 文字列
data カラム説明     = 文字列?

// ドメイン
data ドメイン名物理 = 文字列
data ドメイン名論理 = 文字列
data ドメイン概要   = 文字列

// 採番
data 採番対象ID  = 文字列
data 採番名称    = 文字列
data シーケンス名 = 文字列
data フォーマット = 文字列      // 採番フォーマット文字列
data 採番ユーティリティメソッド名 = 文字列

// API
data API_ID    = 文字列
data API名称   = 文字列

// 電文
data 電文ID    = 文字列
data 電文名    = 文字列
data ファイルID = 文字列
data ファイル名 = 文字列
data レコードID = 文字列
data レコード名 = 文字列

// ジョブ
data ジョブネットID = 文字列
data ジョブネット名 = 文字列
data ジョブID = 文字列
data ジョブ名 = 文字列
data バッチ処理ID = 文字列
data バッチ処理名 = 文字列

// 単純値（データ型・桁数など）
data データ型     = 文字列      // 例: 文字列／数値／日付／タイムスタンプ／バイト列／真偽値
data 桁数         = 整数
data 最大桁数     = 整数
data 最小桁数     = 整数
data 小数部桁数   = 整数
data バイト長     = 整数        // 開始位置算出に使う Byte 数
data 開始位置     = 整数        // 1始まり、固定長レコード内
data 多重度       = 文字列      // 0..1, 1..1, 0..*, 1..* 等
data 必須         = 必須あり OR 任意   // ○／−（空欄）に対応
data 必須あり = 真
data 任意    = 偽
data デフォルト値 = 文字列?
data フォーマット仕様 = 文字列? // 例: yyyyMMdd, ###,###
data パディング   = ﾊﾟﾃﾞｨﾝｸﾞあり OR ﾊﾟﾃﾞｨﾝｸﾞなし
data ﾊﾟﾃﾞｨﾝｸﾞあり = 文字列     // 文字＋方向（例: 0埋め右）
data ﾊﾟﾃﾞｨﾝｸﾞなし = 真
data 小数点位置   = 整数?        // 固定長で 暗黙小数点の桁
data 備考         = 文字列?
data 説明         = 文字列?
data 開始日       = 日付
data 終了日       = 日付
data 日付         = 文字列      // ISO-8601
data 日時         = 文字列      // ISO-8601


// ============================================================
// §1. 設計書一覧（カタログ）
//   出典: Nablarch開発標準設計書一覧.xlsx「2.2 設計書一覧」
// ============================================================

data 設計書カタログ =
  List<カタログエントリ>     // 全34エントリ＋規約類

data カタログエントリ =
  カテゴリ
  AND 小カテゴリ?
  AND 設計書名
  AND 形式               // Excel / Word / -
  AND 説明
  AND 作成単位
  AND 提供有無
  AND ライセンス形態      // CC4 等

data カテゴリ =
  開発プロセス標準
  OR アプリケーション開発標準
  OR 設計ドキュメント

data 小カテゴリ =
  設計標準 OR テスト標準
  OR 標準書式
  OR システム機能設計
  OR 共通コンポーネント設計
  OR インタフェース設計
  OR 画面設計
  OR 帳票設計
  OR メール設計
  OR メッセージ設計
  OR コード設計
  OR データモデル設計
  OR ジョブフロー設計
  OR テスト仕様書

data 形式 = Excel OR Word OR 形式なし
data Excel = 真
data Word  = 真
data 形式なし = 真   // ER図など外部ツール管理のもの

data 作成単位 =
  システム単位
  OR サブシステム単位
  OR 機能単位
  OR 取引単位
  OR コンポーネント単位
  OR 帳票単位
  OR 電文単位
  OR ファイル単位
  OR 単位なし          // 雛形・規約類

data 提供有無 = 提供あり OR 提供なし
data 提供あり = 真
data 提供なし = 真

data ライセンス形態 = CC4 OR その他ライセンス


// ============================================================
// §2. 設計書ごとに共通する“外装”
//   全 Excel テンプレートに表紙／変更履歴／目次がある
//   出典: 010_フォーマット/000_標準書式/Excel開発標準書式.xlsx
// ============================================================

data 設計書ファイル =
  表紙
  AND 変更履歴
  AND 目次?              // 一覧／テスト仕様書には目次無しのものもある
  AND List<本文シート>
  AND データシート?      // 入力規則のマスタを置く隠しシート

data 表紙 =
  PJ名
  AND システム名
  AND サブシステム名?    // システム単位のものは無い
  AND 成果物名           // = 設計書名
  AND 作成情報
  AND List<改訂情報>     // 表紙にもサマリが載る

data 作成情報 =
  作成者
  AND 作成会社?
  AND 作成日
data 改訂情報 =
  変更者
  AND 変更会社?
  AND 変更日

data 変更履歴 = List<改訂レコード>
data 改訂レコード =
  改訂番号
  AND 改訂日
  AND 改訂者
  AND 改訂内容
  AND 承認者?

data 改訂番号 = 文字列
data 改訂日   = 日付
data 改訂者   = 文字列
data 改訂内容 = 文字列
data 承認者   = 文字列
data 作成者   = 文字列
data 作成会社 = 文字列
data 作成日   = 日付
data 変更者   = 文字列
data 変更会社 = 文字列
data 変更日   = 日付

data 目次 = List<目次エントリ>
data 目次エントリ = 章番号 AND 章タイトル AND 参照シート名?
data 章番号 = 文字列      // 例: "2.3.1."
data 章タイトル = 文字列
data 参照シート名 = 文字列

// 本文シートは設計書種別ごとの中身（§3〜§14 で個別定義）
data 本文シート =
  システム機能関連シート
  OR 共通コンポーネント関連シート
  OR インタフェース関連シート
  OR 画面関連シート
  OR 帳票関連シート
  OR メール関連シート
  OR メッセージ関連シート
  OR コード関連シート
  OR データモデル関連シート
  OR ジョブフロー関連シート
  OR テスト関連シート

data データシート = List<入力規則マスタ>
data 入力規則マスタ = マスタ名 AND List<選択肢値>
data マスタ名 = 文字列
data 選択肢値 = 文字列


// ============================================================
// §3. システム機能設計
//   出典: 010_フォーマット/010_システム機能設計/*
// ============================================================

// --- 3.1 システム処理フロー ---
data システム処理フロー設計書 =
  表紙 AND 変更履歴 AND 目次
  AND List<機能処理フロー章>
data 機能処理フロー章 =
  機能ID AND 機能名 AND 処理フロー図
data 処理フロー図 = 図形              // 図形オブジェクトでの自由記述

// --- 3.2 システム機能一覧 ---
data システム機能一覧 = List<システム機能エントリ>
data システム機能エントリ =
  No
  AND 機能ID
  AND 機能名
  AND 機能説明
  AND 取引ID
  AND 取引名
  AND 取引説明
  AND 処理方式
  AND 備考?
data No = 整数
data 処理方式 =
  処理方式_Webサービス
  OR 処理方式_バッチ
  OR 処理方式_メッセージング
  OR 処理方式_画面
  OR 処理方式_共通コンポーネント
  OR 処理方式_帳票
  OR 処理方式_メール

// --- 3.3 リクエスト一覧 ---
data リクエスト一覧 = List<リクエストエントリ>
data リクエストエントリ =
  No
  AND 機能ID
  AND 機能名
  AND リクエストID
  AND リクエスト名
  AND リクエスト説明

// --- 3.4 システム機能設計書（共通骨格） ---
//   どの方式（Web/バッチ/メッセージング/画面）でも 1.x 取引概要 と
//   2.x 取引詳細 の二段構造を持つ
data システム機能設計書 =
  Webサービス取引設計
  OR バッチ取引設計
  OR メッセージング取引設計
  OR 画面取引設計

// --- 3.4.1 Webサービス取引 ---
data Webサービス取引設計 =
  Webサービス取引概要
  AND 処理フロー図
  AND List<API取引詳細>      // ※1取引が複数APIを持つこともある
data Webサービス取引概要 =
  取引ID
  AND 取引名
  AND 取引概要
  AND API_ID
  AND API名称
  AND リクエストURL
  AND HTTPメソッド
  AND 前提事項?
data リクエストURL = 文字列     // ":id" などのパスパラメータを含む可
data HTTPメソッド =
  GET OR POST OR PUT OR DELETE OR PATCH OR HEAD OR OPTIONS

data API取引詳細 =
  入出力一覧
  AND 処理結果一覧_HTTP
  AND 入力データ定義
  AND 処理詳細
  AND 出力データ定義

data 処理結果一覧_HTTP = List<処理結果_HTTP>
data 処理結果_HTTP =
  No AND HTTPステータスコード AND 処理結果説明
data HTTPステータスコード = 整数   // 200, 400, 404, 500 等
data 処理結果説明 = 文字列

// --- 3.4.2 バッチ取引 ---
data バッチ取引設計 =
  バッチ取引概要
  AND バッチ処理一覧
  AND バッチ処理フロー
  AND List<バッチ処理詳細>
data バッチ取引概要 =
  取引ID
  AND 取引名
  AND 取引概要
  AND 起動条件
  AND 前提事項?
data 起動条件 = 文字列
data バッチ処理一覧 = List<バッチ処理一覧エントリ>
data バッチ処理一覧エントリ =
  No
  AND バッチ処理ID
  AND バッチ処理名
  AND 常駐区分
  AND 多重化要否
  AND 処理概要
data 常駐区分 = 常駐 OR 非常駐
data 多重化要否 =
  多重化_プロセス?
  AND 多重化_スレッド?
data 多重化_プロセス = 整数      // 多重数
data 多重化_スレッド = 整数
data バッチ処理フロー = 処理フロー図

data バッチ処理詳細 =
  処理概要セクション
  AND 起動パラメータ
  AND 処理結果一覧_終了コード
  AND 入出力一覧
  AND 入力データ定義
  AND 処理詳細
  AND 出力データ定義
data 処理概要セクション =
  処理単位
  AND 処理順序
  AND リカバリ方法
data 処理単位 = 文字列
data 処理順序 = 文字列
data リカバリ方法 = 文字列
data 起動パラメータ = List<起動パラメータエントリ>
data 起動パラメータエントリ =
  No
  AND 起動パラメータ名_論理
  AND 必須
  AND パラメータ値
  AND 起動パラメータ説明
  AND 起動パラメータ名_物理
data 起動パラメータ名_論理 = 文字列
data 起動パラメータ名_物理 = 文字列
data パラメータ値 = 文字列
data 起動パラメータ説明 = 文字列

data 処理結果一覧_終了コード = List<処理結果_終了コード>
data 処理結果_終了コード =
  No AND 終了コード AND 障害コード? AND 処理結果説明
data 終了コード = 整数
data 障害コード = 文字列

// --- 3.4.3 メッセージング取引 ---
data メッセージング取引設計 =
  メッセージング取引概要
  AND 処理フロー図
  AND List<メッセージング取引詳細>
data メッセージング取引概要 =
  取引ID
  AND 取引名
  AND 取引概要
  AND 前提事項?
data メッセージング取引詳細 =
  入出力一覧
  AND 処理結果一覧_終了コード
  AND 入力データ定義
  AND 処理詳細
  AND 出力データ定義

// --- 3.4.4 画面取引 ---
data 画面取引設計 =
  画面取引概要
  AND List<画面取引詳細>
data 画面取引概要 =
  取引ID
  AND 取引名
  AND 取引概要
  AND 想定利用ユーザ
  AND 前提事項?
data 画面取引詳細 =
  画面ID
  AND 画面名
  AND 画面レイアウト
  AND 一覧表示?
  AND 画面項目定義
  AND 入出力一覧
  AND 画面イベント一覧
  AND List<画面イベント詳細>
  AND 画面引継ぎ項目?       // 内部設計情報
data 画面レイアウト = 図形
data 一覧表示 = List<一覧表示エントリ>
data 一覧表示エントリ =
  No
  AND 領域名
  AND ページング有無
  AND ソート条件
  AND 備考?
data 領域名 = 文字列
data ページング有無 = ページングあり OR ページングなし
data ソート条件 = 文字列

data 画面項目定義 = List<画面項目グループ>
data 画面項目グループ =
  領域名
  AND List<画面項目>
data 画面項目 =
  No
  AND 表示情報
  AND 画面項目名_物理       // 内部設計情報
  AND ドメイン名論理?       // 入力項目のみ
data 表示情報 =
  画面項目名
  AND 画面項目種別
  AND 情報取得元?
  AND 編集仕様?
  AND 初期値?
  AND 必須
data 画面項目名 = 文字列
data 画面項目名_物理 = 文字列
data 画面項目種別 =
  種別_label
  OR 種別_text
  OR 種別_textarea
  OR 種別_select_pulldown
  OR 種別_radio
  OR 種別_checkbox
  OR 種別_hidden
  OR 種別_file
  OR 種別_button
  OR 種別_link
  OR 種別_image
data 情報取得元 = 文字列     // 例: 企業.企業コード, 共通コンポ呼び出し
data 編集仕様   = 文字列     // フォーマット指定や表示変換
data 初期値     = 文字列

data 画面イベント一覧 = List<画面イベントエントリ>
data 画面イベントエントリ =
  No
  AND 画面イベント名
  AND 発生タイミング
  AND 画面イベント概要
  AND 正常時遷移先画面?
  AND サーバ通信有無
data 画面イベント名 = 文字列
data 発生タイミング = 文字列
data 画面イベント概要 = 文字列
data サーバ通信有無 =
  通信あり_同期 OR 通信あり_非同期 OR 通信なし

data 画面イベント詳細 =
  画面イベント名
  AND バリデーション処理一覧?
  AND DBアクセス_検索?
  AND DBアクセス_登録?
  AND DBアクセス_更新?
  AND DBアクセス_削除?
  AND 共通コンポーネント呼び出し一覧?
  AND 画面遷移処理?
  AND 出力データ定義?
data バリデーション処理一覧 = List<バリデーション指定>
data バリデーション指定 =
  No
  AND バリデーション名
  AND バリデーション内容
  AND メッセージID
  AND 埋め込み文字列?
  AND 後続バリデーションの続行判定
data バリデーション名 = 文字列
data バリデーション内容 = 文字列
data 後続バリデーションの続行判定 = 続行 OR 中断 OR 該当なし
data 続行 = 真
data 中断 = 真
data 該当なし = 真

data 共通コンポーネント呼び出し一覧 = List<共通コンポーネント呼び出し>
data 共通コンポーネント呼び出し =
  共通コンポーネントID
  AND 共通コンポーネント処理名
  AND エラー番号?
data 共通コンポーネント処理名 = 文字列
data エラー番号 = 文字列

data 画面遷移処理 = List<画面遷移エントリ>
data 画面遷移エントリ =
  遷移条件 AND 遷移先画面ID? AND 遷移先取引ID?
data 遷移条件 = 文字列
data 遷移先画面ID = 文字列
data 遷移先取引ID = 文字列

data 画面引継ぎ項目 = List<画面引継ぎグループ>
data 画面引継ぎグループ =
  項目グループ名
  AND プレフィックス?
  AND List<画面引継ぎ項目エントリ>
data 項目グループ名 = 文字列
data プレフィックス = 文字列
data 画面引継ぎ項目エントリ =
  No
  AND 引継ぎ項目名
  AND 格納先
  AND 設定値
  AND 項目説明
data 引継ぎ項目名 = 文字列
data 格納先       = 文字列    // request, session, etc.
data 設定値       = 文字列
data 項目説明     = 文字列

// --- 3.5 共通の章（システム機能設計書のいずれの方式でも使う） ---
data 入出力一覧 = List<入出力エントリ>
data 入出力エントリ =
  No
  AND 入出力名
  AND 入出力種別
  AND IO区分
  AND DBアクセス種別?       // 種別=テーブル の場合のみ
  AND 備考?
data 入出力名 = 文字列
data 入出力種別 =
  種別_テーブル
  OR 種別_ファイル
  OR 種別_電文
  OR 種別_メール
  OR 種別_画面
  OR 種別_帳票
  OR 種別_その他
data IO区分 = I OR O OR IO
data DBアクセス種別 =
  C有無 AND R有無 AND U有無 AND D有無 AND ロック対象有無
data C有無 = あり OR なし
data R有無 = あり OR なし
data U有無 = あり OR なし
data D有無 = あり OR なし
data ロック対象有無 = あり OR なし
data あり = 真
data なし = 真

data 入力データ定義 =
  項目定義?               // 電文ID/電文名で外部I/F設計書を参照する場合は省略可
  AND 編集仕様詳細?
data 項目定義 = List<項目>
data 項目 =
  No
  AND 項目論理名
  AND 項目物理名?
  AND 必須
  AND ドメイン名論理
  AND データ型?
  AND 桁数?
  AND 備考?
data 項目論理名 = 文字列
data 項目物理名 = 文字列

data 編集仕様詳細 = List<編集仕様エントリ>
data 編集仕様エントリ =
  No
  AND 項目ID
  AND 項目名
  AND 編集元
  AND 編集仕様
  AND 備考?
data 項目ID = 文字列
data 項目名 = 文字列
data 編集元 =
  電文_テーブル参照
  OR 固定値
  OR 計算
data 電文_テーブル参照 =
  電文orテーブル名
  AND 参照項目名
data 電文orテーブル名 = 文字列
data 参照項目名 = 文字列
data 固定値 = 文字列
data 計算   = 文字列

data 出力データ定義 =
  項目定義?
  AND 編集仕様詳細?

data 処理詳細 = List<処理ステップ>
data 処理ステップ =
  処理名称
  AND 処理ロジック
data 処理名称 = 文字列
data 処理ロジック = 文字列         // 自然言語＋疑似コード


// ============================================================
// §4. 共通コンポーネント設計
//   出典: 010_フォーマット/020_共通コンポーネント設計/*
// ============================================================

data 共通コンポーネント一覧 =
  システム内共通エリア
  AND サブシステム内共通エリア
  AND List<機能共通エリア>
data システム内共通エリア = List<共通コンポーネント一覧エントリ>
data サブシステム内共通エリア = List<共通コンポーネント一覧エントリ>
data 機能共通エリア =
  機能ID AND 機能名 AND List<共通コンポーネント一覧エントリ>
data 共通コンポーネント一覧エントリ =
  No
  AND 共通コンポーネントID
  AND 共通コンポーネント名
  AND クラス名
  AND 処理名
  AND メソッド名
  AND 処理概要

data 共通コンポーネント設計書 = List<共通コンポーネント定義>
data 共通コンポーネント定義 =
  共通コンポーネントID
  AND 共通コンポーネント名
  AND 処理名
  AND 処理説明
  AND 処理概要セクションCC
  AND 注意事項?
  AND クラス名
  AND メソッド名
  AND 入出力パラメータ
  AND CRUD一覧
  AND エラー情報
  AND 処理定義
data 処理概要セクションCC = 文字列
data 注意事項 = 文字列

data 入出力パラメータ = List<パラメータエントリ>
data パラメータエントリ =
  項目名
  AND IO区分
  AND データ型
  AND 必須
  AND 項目説明

data CRUD一覧 = List<CRUDエントリ>
data CRUDエントリ =
  物理テーブル名
  AND C有無 AND R有無 AND U有無 AND D有無
  AND 備考?

data エラー情報 = List<エラーエントリ>
data エラーエントリ =
  エラー番号
  AND エラー名
  AND エラー種別
  AND メッセージID
  AND 埋め込み文字列?
  AND エラー概要
data エラー名 = 文字列
data エラー種別 = 文字列
data エラー概要 = 文字列

data 処理定義 = List<処理定義エントリ>
data 処理定義エントリ =
  処理ステップ
  AND 呼び出し共通コンポーネントID?
  AND 呼び出し処理名?
  AND 関連エラー番号?
data 呼び出し共通コンポーネントID = 文字列
data 呼び出し処理名 = 文字列
data 関連エラー番号 = 文字列


// ============================================================
// §5. インタフェース設計
//   出典: 010_フォーマット/030_インタフェース設計/*
// ============================================================

data WebサービスAPI一覧 =
  概要セクション
  AND List<API一覧エントリ>
data 概要セクション =
  説明文
  AND コンテキストルート
  AND APIバージョン
data 説明文 = 文字列
data コンテキストルート = 文字列
data APIバージョン = 文字列

data API一覧エントリ =
  No
  AND API_ID
  AND API名称
  AND 処理概要
  AND プロトコル
  AND HTTPメソッド
  AND リクエストURL
  AND データ形式_API
  AND I_F電文
  AND 処理対象取引
data プロトコル = HTTP OR HTTPS OR その他プロトコル
data その他プロトコル = 文字列
data データ形式_API =
  形式_request
  AND 形式_response
  AND 文字コード
data 形式_request = 文字列    // JSON, XML, FormUrlEncoded 等
data 形式_response = 文字列
data 文字コード = 文字列      // UTF-8, Shift_JIS 等
data I_F電文 =
  入力電文ID
  AND 出力電文ID
data 入力電文ID = 文字列
data 出力電文ID = 文字列
data 処理対象取引 = 取引ID AND 取引名

data 外部インタフェース一覧 = List<外部I_Fエントリ>
data 外部I_Fエントリ =
  No
  AND ファイルID_電文ID
  AND 外部インタフェース名
  AND 入出力種別_外部
  AND 相手先
  AND 媒体
  AND 授受方式
  AND 暗号化有無
  AND 文字コード
  AND 処理サイクル
  AND データ量
  AND ファイル保存期間日数?
  AND 備考?
data ファイルID_電文ID = 文字列
data 外部インタフェース名 = 文字列
data 入出力種別_外部 = 入力 OR 出力 OR 双方向
data 相手先 = 文字列
data 媒体 = 媒体_ファイル OR 媒体_HTTP OR 媒体_MQ OR 媒体_その他
data 媒体_その他 = 文字列
data 授受方式 = 文字列     // 例: SFTP, REST, MQ Queue名
data 暗号化有無 = 暗号化あり OR 暗号化なし
data 暗号化あり = 暗号化方式 AND 鍵情報?
data 暗号化方式 = 文字列
data 鍵情報 = 文字列
data 処理サイクル =
  サイクル種別
  AND サイクル詳細
data サイクル種別 = 文字列    // 日次 / 週次 / 月次 / オンデマンド 等
data サイクル詳細 = 文字列    // 起動時刻、実行曜日 等
data データ量 =
  レコード長Byte
  AND 件数_ピーク時件数
data レコード長Byte = 整数
data 件数_ピーク時件数 = 整数
data ファイル保存期間日数 = 整数

// --- 5.x 外部インタフェース設計書（HTTP共通） ---
data 外部I_F設計書_HTTP共通 =
  HTTPバージョン
  AND HTTPヘッダ_リクエスト
  AND HTTPヘッダ_レスポンス
  AND パラメータ仕様
  AND HTTPステータス一覧
  AND 認証認可
data HTTPバージョン = 文字列
data HTTPヘッダ_リクエスト = List<HTTPヘッダエントリ>
data HTTPヘッダ_レスポンス = List<HTTPヘッダエントリ>
data HTTPヘッダエントリ =
  No
  AND ヘッダ名
  AND ヘッダ内容
  AND ヘッダ値
  AND 備考?
data ヘッダ名 = 文字列
data ヘッダ内容 = 文字列
data ヘッダ値 = 文字列
data パラメータ仕様 = List<パラメータ仕様エントリ>
data パラメータ仕様エントリ =
  条件
  AND 仕様
data 条件 = 文字列
data 仕様 = 文字列
data HTTPステータス一覧 = List<HTTPステータスエントリ>
data HTTPステータスエントリ =
  No
  AND HTTPステータスコード
  AND ReasonPhrase
  AND エラー内容
  AND レスポンスボディ有無
  AND 補足?
data ReasonPhrase = 文字列
data エラー内容 = 文字列
data レスポンスボディ有無 = ボディあり OR ボディなし
data ボディあり = 真
data ボディなし = 真
data 補足 = 文字列
data 認証認可 = 文字列

// --- 5.x 外部インタフェース設計書（電文／ファイル本体） ---
data 外部I_F設計書 =
  外部I_F仕様
  AND レコード構成
  AND List<レコード定義>
  AND データ構成サンプル?
  AND データ構成イメージ?
data 外部I_F仕様 =
  入出力種別_外部
  AND 相手先
  AND 入出力取引IDor名称
  AND ファイル_電文識別
  AND 目的概要
  AND 作成条件
  AND 媒体
  AND データ形式_電文
  AND 授受方式
  AND ﾌｨｰﾙﾄﾞｾﾊﾟﾚｰﾀ?
  AND 暗号化有無
  AND 改行コード?
  AND 文字コード
  AND レコード長?
  AND 処理サイクル
  AND 特記事項?
data 入出力取引IDor名称 = 文字列
data ファイル_電文識別 =
  ファイルID OR 電文ID
data 目的概要 = 文字列
data 作成条件 = 文字列
data データ形式_電文 =
  形式_I_Fファイル OR 形式_JSON OR 形式_XML OR 形式_その他電文
data 形式_その他電文 = 文字列
data ﾌｨｰﾙﾄﾞｾﾊﾟﾚｰﾀ = 文字列
data 改行コード = 文字列
data レコード長 = 整数
data 特記事項 = 文字列

data レコード構成 =
  List<レコード構成エントリ>
  AND ソートKEY
  AND レコード構成イメージ?
data レコード構成エントリ =
  No
  AND レコード名
  AND ﾚｺｰﾄﾞﾀｲﾌﾟ名
  AND 識別方法
  AND レコード長?
  AND 繰り返し回数
  AND 繰り返し単位
data ﾚｺｰﾄﾞﾀｲﾌﾟ名 = 文字列
data 識別方法 = 文字列
data 繰り返し回数 = 整数
data 繰り返し単位 = 文字列
data ソートKEY = List<ソートKEYエントリ>
data ソートKEYエントリ =
  ソートKEY項目名
  AND 昇順降順
  AND 優先度
data ソートKEY項目名 = 文字列
data 昇順降順 = 昇順 OR 降順
data 優先度 = 整数

// レコード定義: 形式によって列構成が違う
data レコード定義 =
  レコード名
  AND レコードID?
  AND List<電文項目>
data 電文項目 =
  電文項目_固定長
  OR 電文項目_JSON
  OR 電文項目_XML
data 電文項目_固定長 =
  No
  AND 項目名
  AND 項目ID
  AND ドメイン名論理
  AND 必須
  AND データ型
  AND バイト長
  AND 開始位置
  AND デフォルト値?
  AND パディング
  AND 小数点位置?
  AND フォーマット仕様?
  AND 備考?
data 電文項目_JSON =
  No
  AND 項目名
  AND 項目ID
  AND ドメイン名論理
  AND 必須
  AND データ型
  AND 桁数
  AND 多重度
  AND デフォルト値?
  AND フォーマット仕様?
  AND 備考?
data 電文項目_XML =
  No
  AND 項目名
  AND 項目ID
  AND ドメイン名論理
  AND 必須
  AND XML属性区分        // 要素 or 属性
  AND データ型
  AND 桁数
  AND 多重度
  AND デフォルト値?
  AND フォーマット仕様?
  AND 備考?
data XML属性区分 = 要素 OR 属性
data データ構成サンプル = 文字列     // サンプル文字列
data データ構成イメージ = 図形


// ============================================================
// §6. 画面設計
//   出典: 010_フォーマット/040_画面設計/*
// ============================================================

data 画面一覧 = List<画面一覧エントリ>
data 画面一覧エントリ =
  No
  AND 機能ID
  AND 機能名
  AND 画面ID
  AND 画面名
  AND 画面説明

data 画面遷移図 = List<画面遷移図エントリ>
data 画面遷移図エントリ =
  機能ID
  AND 機能名
  AND 遷移図                // 図形オブジェクトでの自由記述
data 遷移図 = 図形


// ============================================================
// §7. 帳票設計
//   出典: 010_フォーマット/050_帳票設計/*
// ============================================================

data 帳票一覧 = List<帳票一覧エントリ>
data 帳票一覧エントリ =
  No
  AND 帳票ID
  AND 帳票名
  AND 帳票概要
  AND 帳票様式
  AND 用紙サイズ
  AND 用紙向き
  AND ページ数
  AND 処理方式
  AND 出力タイミング
  AND 出力元取引
data 帳票様式 = 文字列
data 用紙サイズ = A3 OR A4 OR A5 OR B4 OR B5 OR その他用紙
data その他用紙 = 文字列
data 用紙向き = 縦 OR 横
data ページ数 = 整数
data 出力タイミング = 文字列
data 出力元取引 = 取引ID AND 取引名

data 帳票設計書 =
  帳票概要セクション
  AND 帳票レイアウト
  AND 帳票項目定義
  AND 帳票_カメラ用シート?    // 印刷不要の原本シート
data 帳票概要セクション =
  帳票ID
  AND 帳票名
  AND 帳票概要
  AND 帳票様式
  AND 用紙サイズ
  AND 用紙向き
  AND ページ数
  AND 処理方式
  AND 出力タイミング
  AND 出力元取引
data 帳票レイアウト = 図形

data 帳票項目定義 =
  項目グループ設計
  AND 項目設計
data 項目グループ設計 = List<項目グループエントリ>
data 項目グループエントリ =
  No
  AND 項目グループ名
  AND 項目グループ単位の出力条件
  AND 2ページ目以降の出力有無
  AND 一覧表示_明細
data 項目グループ単位の出力条件 = 文字列
data 2ページ目以降の出力有無 = 出力あり OR 出力なし
data 一覧表示_明細 =
  明細の単位
  AND 明細の数
  AND 並び順
data 明細の単位 = 文字列
data 明細の数 = 整数
data 並び順 = 文字列

data 項目設計 = List<項目グループ別項目>
data 項目グループ別項目 =
  項目グループ参照番号
  AND 項目グループ名
  AND List<帳票項目>
data 項目グループ参照番号 = 整数
data 帳票項目 =
  No
  AND 項目名
  AND 必須
  AND データタイプ
  AND 表示最大Byte数
  AND 揃え
  AND フォント
  AND デフォルト値?
  AND 編集仕様?
  AND 取得元_テーブルorファイルor画面
  AND 取得元_カラムor項目
  AND 備考?
data データタイプ = 文字列
data 表示最大Byte数 = 整数
data 揃え =
  横揃え
  AND 縦揃え
data 横揃え = 左 OR 中央 OR 右
data 縦揃え = 上 OR 中央縦 OR 下
data フォント =
  フォント種類
  AND フォントサイズ
data フォント種類 = 文字列
data フォントサイズ = 整数
data 取得元_テーブルorファイルor画面 = 文字列
data 取得元_カラムor項目 = 文字列
data 帳票_カメラ用シート = 図形


// ============================================================
// §8. メール設計
//   出典: 010_フォーマット/060_メール設計/*
// ============================================================

data メール一覧 = List<メール一覧エントリ>
data メール一覧エントリ =
  No
  AND メールID
  AND メール名
  AND メール概要
  AND 送信先
  AND 送信元
  AND エラー時送信先
  AND 暗号化要否
  AND メール形式
  AND 添付ファイル有無
  AND メールテンプレートID
  AND 処理方式
  AND 送信タイミング
  AND 送信元取引
data 送信先 = 文字列
data 送信元 = 文字列
data エラー時送信先 = 文字列
data 暗号化要否 = 必要 OR 不要
data メール形式 = テキスト OR HTML
data 添付ファイル有無 = 添付あり OR 添付なし
data 送信タイミング = 文字列
data 送信元取引 = 取引ID AND 取引名

data メール設計書 = List<メール定義>
data メール定義 =
  メール名
  AND メールID
  AND メール概要
  AND 件名
  AND 件名_文字コード
  AND 送信元_From
  AND 送信元_Replyto?
  AND 送信先_To
  AND 送信先_Cc?
  AND 送信先_Bcc?
  AND 本文文字コード
  AND メール形式
  AND 本文
  AND メールテンプレートID
  AND メールテンプレート名
  AND 埋め込み文字列定義
  AND 電子署名?
  AND 添付ファイル定義?
  AND メールヘッダ?
data 件名 = 文字列
data 件名_文字コード = 文字コード
data 送信元_From = 文字列
data 送信元_Replyto = 文字列
data 送信先_To = 文字列
data 送信先_Cc = 文字列
data 送信先_Bcc = 文字列
data 本文文字コード = 文字コード
data 本文 = 文字列            // テンプレート文字列。{0} などのプレースホルダ含む
data 埋め込み文字列定義 = List<埋め込み文字列エントリ>
data 埋め込み文字列エントリ =
  項目名
  AND 物理名
  AND 表示桁数_半角
  AND 編集仕様?
  AND 備考?
data 物理名 = 文字列
data 表示桁数_半角 = 整数

data 電子署名 = 文字列         // 署名内容ないし証明書ID
data 添付ファイル定義 = List<添付ファイルエントリ>
data 添付ファイルエントリ =
  添付ファイル概要
  AND 添付ファイル種類
  AND 添付ファイル作成仕様
data 添付ファイル概要 = 文字列
data 添付ファイル種類 = 文字列
data 添付ファイル作成仕様 = 文字列
data メールヘッダ = List<メールヘッダエントリ>
data メールヘッダエントリ =
  ヘッダ名
  AND ヘッダ内容


// ============================================================
// §9. メッセージ設計
//   出典: 010_フォーマット/070_メッセージ設計/メッセージ設計書
// ============================================================

data メッセージ設計書 =
  メッセージ_ja
  AND メッセージ_en?
  AND メッセージ_ch?
data メッセージ_ja = List<メッセージエントリ>
data メッセージ_en = List<メッセージエントリ>
data メッセージ_ch = List<メッセージエントリ>
data メッセージエントリ =
  No
  AND メッセージID
  AND メッセージ内容
  AND 備考?


// ============================================================
// §10. コード設計
//   出典: 010_フォーマット/080_コード設計/コード設計書
// ============================================================

data コード設計書 =
  コード_ja
  AND コード_en?
data コード_ja = List<コードエントリ>
data コード_en = List<コードエントリ>
data コードエントリ =
  No
  AND コードID
  AND コード名称
  AND コード説明
  AND List<コード値定義>
data コード値定義 =
  コード値
  AND ソート順
  AND コード名
  AND コード略称?
  AND List<オプション名称>      // 1〜10 まで列を持つ（言語非依存だが任意）
  AND List<コードパターン>      // 1〜20。フラグの組合せでパターン分け
data オプション名称 =
  オプション番号
  AND オプション値
data オプション番号 = 整数      // 1〜10
data オプション値 = 文字列
data コードパターン =
  パターン番号
  AND パターン値
data パターン番号 = 整数        // 1〜20
data パターン値 = 文字列        // ○／− 等


// ============================================================
// §11. データモデル設計
//   出典: 010_フォーマット/090_データモデル設計/*
// ============================================================

// --- 11.1 テーブル一覧 ---
data テーブル一覧 = List<テーブル一覧エントリ>
data テーブル一覧エントリ =
  No
  AND 主管サブシステム
  AND 論理テーブル名
  AND 物理テーブル名
  AND 備考?
data 主管サブシステム =
  サブシステムID AND サブシステム名

// --- 11.2 テーブル定義書 ---
data テーブル定義書 = List<テーブル定義>
data テーブル定義 =
  論理テーブル名
  AND 物理テーブル名
  AND テーブル説明
  AND List<カラム定義>
data カラム定義 =
  No
  AND 論理カラム名
  AND 物理カラム名
  AND ドメイン名論理
  AND データ型
  AND 桁数
  AND PK指定
  AND 必須
  AND INDEX指定          // INDEX1〜7
  AND 項目定義詳細?
  AND デフォルト値?
  AND 暗号化対象有無
  AND 備考?
data PK指定 = PK含む OR PK含まない
data PK含む = PK順序        // 主キー内の位置（1始まり）
data PK含まない = 真
data PK順序 = 整数
data INDEX指定 =
  INDEX1? AND INDEX2? AND INDEX3? AND INDEX4?
  AND INDEX5? AND INDEX6? AND INDEX7?
data INDEX1 = INDEX順序     // INDEX1 内での列順
data INDEX2 = INDEX順序
data INDEX3 = INDEX順序
data INDEX4 = INDEX順序
data INDEX5 = INDEX順序
data INDEX6 = INDEX順序
data INDEX7 = INDEX順序
data INDEX順序 = 整数
data 項目定義詳細 = 文字列
data 暗号化対象有無 = 暗号化対象 OR 暗号化非対象
data 暗号化対象 = 真
data 暗号化非対象 = 真

// --- 11.3 ドメイン定義書 ---
data ドメイン定義書 =
  ドメイン定義
  AND バリデーション定義_標準
  AND バリデーション定義_独自?
data ドメイン定義 = List<ドメインエントリ>
data ドメインエントリ =
  No
  AND ドメイン名論理
  AND ドメイン概要
  AND データ型
  AND 桁数情報
  AND コード制約?
  AND その他制約?
  AND バリデーション処理名
  AND ドメイン名物理
  AND システム許容文字?
  AND 追加アノテーション?
data 桁数情報 =
  最小桁数?
  AND 最大桁数?
  AND 小数部桁数?
data コード制約 =
  コードID
  AND コードパターン名?
data コードパターン名 = 文字列
data その他制約 = 文字列
data システム許容文字 = 文字列
data 追加アノテーション = 文字列

// 標準提供19種＋独自バリデーション
data バリデーション定義_標準 = List<バリデーション定義エントリ>
data バリデーション定義_独自 = List<バリデーション定義エントリ>
data バリデーション定義エントリ =
  No
  AND バリデーション処理名
  AND 処理内容
  AND メッセージ情報
data バリデーション処理名 =
  // 標準提供19種は固定値、独自は任意名
  V_文字種_ASCII
  OR V_文字種_半角英数字
  OR V_文字種_半角数字
  OR V_文字種_全角文字
  OR V_文字種_システム許容文字
  OR V_文字数_桁数固定
  OR V_文字数_桁数可変_最大のみ
  OR V_文字数_桁数可変_最大最小
  OR V_数値桁数_小数部指定
  OR V_数値桁数_小数部未指定
  OR V_数値範囲_最大のみ
  OR V_数値範囲_最小のみ
  OR V_数値範囲_最大最小
  OR V_要素数_最大のみ
  OR V_要素数_最小のみ
  OR V_要素数_最大最小
  OR V_コード値有効
  OR V_列挙値
  OR V_日付書式
  OR V_独自                  // バリエーション名は文字列
data V_独自 = 文字列
data 処理内容 = 文字列
data メッセージ情報 =
  メッセージID
  AND 埋め込み文字列?

// --- 11.4 採番一覧 ---
data 採番一覧 = List<採番エントリ>
data 採番エントリ =
  No
  AND 採番対象ID
  AND 採番名称
  AND フォーマット
  AND 採番ユーティリティメソッド名
  AND 抜け番許容
  AND シーケンス名
  AND サイクリック指定
  AND 採番初期値
  AND 採番最小値
  AND 採番最大値
  AND 採番増分
  AND 初期化タイミング
  AND 備考?
data 抜け番許容 = 抜け番あり OR 抜け番なし
data サイクリック指定 = サイクル有 OR サイクル無
data 採番初期値 = 整数
data 採番最小値 = 整数
data 採番最大値 = 整数
data 採番増分 = 整数
data 初期化タイミング = 文字列


// ============================================================
// §12. ジョブフロー設計
//   出典: 010_フォーマット/100_ジョブフロー設計/ネット・ジョブフロー
// ============================================================

data ネットジョブフロー設計書 = List<スケジュール条件単位>
data スケジュール条件単位 =
  スケジュール条件
  AND List<ジョブネット>
data スケジュール条件 = 文字列        // 例: 月次（23日夜間）
data ジョブネット =
  ジョブネットID
  AND ジョブネット名
  AND 起動時間または最遅開始時刻
  AND 最遅終了時刻
  AND List<ジョブ>
data 起動時間または最遅開始時刻 = 文字列   // hh:mm 形式
data 最遅終了時刻 = 文字列
data ジョブ =
  ジョブID
  AND ジョブ名
  AND バッチ処理ID
  AND バッチ処理名
  AND 先行ジョブ?              // 依存関係（無いと先頭ジョブ）
  AND 後続ジョブ一覧
data 先行ジョブ = List<ジョブID>
data 後続ジョブ一覧 = List<ジョブID>


// ============================================================
// §13. テスト仕様書
//   出典: 010_フォーマット/110_テスト仕様書/*
//   ・5方式（Webサービス/バッチ/メッセージ/画面/共通コンポーネント）
//   ・3粒度（クラス単体／リクエスト単体／取引単体）
//   ・共通コンポーネントはクラス単体のみ
// ============================================================

data 単体テスト仕様書 =
  単体テスト_Webサービス
  OR 単体テスト_バッチ
  OR 単体テスト_メッセージ
  OR 単体テスト_画面
  OR 単体テスト_共通コンポーネント

data 単体テスト_Webサービス =
  クラス単体観点表_共通
  AND リクエスト単体観点表_Web
  AND 取引単体観点表_共通
data 単体テスト_バッチ =
  クラス単体観点表_共通
  AND リクエスト単体観点表_バッチ
  AND 取引単体観点表_共通
data 単体テスト_メッセージ =
  クラス単体観点表_共通
  AND リクエスト単体観点表_メッセージ
  AND 取引単体観点表_共通
data 単体テスト_画面 =
  クラス単体観点表_共通
  AND リクエスト単体観点表_画面
  AND 取引単体観点表_画面
data 単体テスト_共通コンポーネント =
  クラス単体観点表_共通

// --- 13.1 共通テストケース表ヘッダ ---
data テストケース行 =
  ケースNo
  AND 大項目
  AND 中項目
  AND 小項目
  AND 詳細
  AND 観点
  AND 対象外理由?
  AND 対応設計書
  AND 対応箇所
  AND テスト内容
  AND 想定結果
  AND テストデータシート名?
  AND データNo?
  AND 実施情報
  AND 確認情報
data ケースNo = 文字列        // 例: 1-1-1
data 大項目 = 文字列
data 中項目 = 文字列
data 小項目 = 文字列
data 詳細   = 文字列
data 観点   = 文字列
data 対象外理由 = 文字列
data 対応設計書 = 文字列
data 対応箇所 = 文字列
data テスト内容 = 文字列
data 想定結果 = 文字列
data テストデータシート名 = 文字列
data データNo = 文字列
data 実施情報 = 実施者? AND 実施日? AND 実施結果?
data 確認情報 = 確認者? AND 確認日?
data 実施者 = 文字列
data 実施日 = 日付
data 実施結果 = OK OR NG OR 未実施
data OK = 真
data NG = 真
data 未実施 = 真
data 確認者 = 文字列
data 確認日 = 日付

// --- 13.2 クラス単体（5方式すべて共通の観点ツリー） ---
data クラス単体観点表_共通 = List<テストケース行>
// 観点ツリー構造（大→中→小）はテンプレに固定で焼き付いている
// この型で、ケースが「どの観点ノード配下か」を必ず分類できるようにする
data クラス単体観点ノード =
  バリデーション_単項目_必須
  OR バリデーション_単項目_文字列長
  OR バリデーション_単項目_数値
  OR バリデーション_単項目_文字種
  OR バリデーション_単項目_その他          // コード値・日付・メールアドレス・アプリ固有
  OR バリデーション_相関_その他
  OR バリデーション_相関_DB
  OR DB操作_共通_条件
  OR DB操作_共通_登録更新内容
  OR DB操作_検索_実行結果
  OR DB操作_登録_実行結果
  OR DB操作_更新_実行結果
  OR DB操作_削除_実行結果
  OR DB制御_更新順序
  OR DB制御_排他制御
  OR DB制御_ロールバック
  OR DB制御_コミット
  OR ファイル取込_実行結果
  OR ファイルアップロード_実行結果
  OR ファイルアップロード_エラー
  OR ファイルアップロード_バリデーション_フォーマット
  OR ファイル出力_実行結果_フォーマット
  OR ファイルダウンロード_実行結果_フォーマット
  OR ファイルダウンロード_実行結果_エラー
  OR ファイルダウンロード_データ出力_フォーマット
  OR ファイルダウンロード_データ出力_出力内容
  OR ファイル操作_削除
  OR ファイル操作_移動リネーム
  OR ファイル操作_コピー
  OR メール処理_実行結果_コピー
  OR メール処理_実行結果_エラー
  OR メール処理_メール編集_ヘッダ
  OR メール処理_メール編集_件名
  OR メール処理_メール編集_本文
  OR 受信処理_実行結果_本文
  OR 受信処理_バリデーション_フォーマット
  OR 送信処理_実行結果_フォーマット
  OR 送信処理_実行結果_エラー
  OR 送信処理_電文編集_フォーマット
  OR 送信処理_電文編集_出力内容
  OR ログ出力_ファイル操作_出力内容
  OR ログ出力_ログ編集_フォーマット
  OR ログ出力_ログ編集_出力内容

// --- 13.3 リクエスト単体（方式別に固有観点が追加） ---
data リクエスト単体観点表_Web =
  クラス単体観点表_共通
  AND List<Webサービス機能観点>
data Webサービス機能観点 =
  Web_出力内容
  OR Web_HTTPステータス
  OR Web_リクエスト
  OR Web_同時実行数の制限
  OR Web_エラー

data リクエスト単体観点表_バッチ =
  クラス単体観点表_共通
  AND List<バッチアプリ機能観点>
data バッチアプリ機能観点 =
  Batch_出力内容
  OR Batch_入力データ
  OR Batch_終了ステータス
  OR Batch_エラー
  OR Batch_ファイル取込_エラー
  OR Batch_ファイル出力_エラー

data リクエスト単体観点表_メッセージ =
  クラス単体観点表_共通
  AND List<メッセージング機能観点>
data メッセージング機能観点 =
  MQ_出力内容
  OR MQ_入力データ
  OR MQ_エラー

data リクエスト単体観点表_画面 =
  クラス単体観点表_共通
  AND List<画面表示観点>
  AND List<画面操作観点>
  AND DB操作_二重サブミット防止
data 画面表示観点 =
  GUI_画面レイアウト
  OR GUI_UI部品
  OR GUI_一覧
  OR GUI_画面表示データ
data 画面操作観点 =
  OP_イベント実行結果_画面表示データ
  OR OP_イベント実行結果_UI部品
  OR OP_遷移結果_画面遷移
  OR OP_遷移結果_URL直接アクセス
  OR OP_遷移結果_HTTPステータス
  OR OP_遷移結果_ブラウザキャッシュ

// --- 13.4 取引単体（横断テスト。列構成も別） ---
data 取引単体観点表_共通 = List<取引単体ケース行>
data 取引単体観点表_画面  = List<取引単体ケース行_画面>
data 取引単体ケース行 =
  ケースNo
  AND 区分
  AND 確認観点1
  AND 確認観点2
  AND 確認観点3
  AND 対象外理由?
  AND 対応設計書
  AND 対応箇所
  AND テスト内容
  AND 想定結果
  AND テストデータシート名?
  AND データNo?
  AND 実施情報
  AND 確認情報
data 区分 = 文字列
data 確認観点1 = 文字列
data 確認観点2 = 文字列
data 確認観点3 = 文字列
data 取引単体ケース行_画面 =
  取引単体ケース行
  AND 画面遷移パターン?
data 画面遷移パターン =
  パターン_正常取引
  OR パターン_戻るイベント
  OR パターン_検索結果0件
  OR パターン_サブウィンドウ連携
  OR パターン_異常_精査エラー
  OR パターン_異常_検索結果上限超過
  OR パターン_異常_排他制御エラー
  OR パターン_異常_その他
  OR パターン_その他のイベント
  OR パターン_取引の連続実行

// ============================================================
// §14. 設計書「体系図」と「実装対応」
//   出典: Nablarch開発標準設計書一覧.xlsx の 2.1 と 3 章
// ============================================================

// --- 14.1 設計書間の参照関係グラフ ---
//   2.1 設計書体系図に書かれている矢印を data 化する
data 設計書間関係 =
  起点設計書名
  AND 終点設計書名
  AND 関係種別
data 起点設計書名 = 文字列
data 終点設計書名 = 文字列
data 関係種別 = 参照 OR 依存
data 参照 = 真   // 矢印元が先を「参照」（情報の取得元）
data 依存 = 真   // 矢印元が「前提とする」（規約・標準への依存）

// --- 14.2 設計書 → ソースコードの落とし込み ---
data 実装ステレオタイプ =
  Entity OR Form OR バリデーションメソッド OR 共通コンポーネント実装 OR Action実装 OR JSP実装

data 実装対応 =
  実装ステレオタイプ
  AND List<入力設計書>
  AND List<生成成果物>
data 入力設計書 = 文字列      // 設計書名（カタログエントリ参照）
data 生成成果物 = Javaファイル OR SQLファイル OR JSPファイル
data Javaファイル = クラス名
data SQLファイル  = 文字列
data JSPファイル  = 文字列


// ============================================================
// §16. 設計書をリポジトリ化する際の論理ファイル群
//   1設計書を1ファイル化するときの粒度を ID で表現する
// ============================================================

data 設計リポジトリ =
  // システム全体で1つ
  設計書カタログ
  AND コード設計書
  AND ドメイン定義書
  AND メッセージ設計書
  AND テーブル一覧
  // サブシステム単位で多数
  AND List<サブシステム設計セット>

data サブシステム設計セット =
  サブシステムID
  AND サブシステム名
  AND システム機能一覧
  AND システム処理フロー設計書
  AND リクエスト一覧
  AND 共通コンポーネント一覧
  AND 画面一覧
  AND 画面遷移図
  AND 帳票一覧
  AND メール一覧
  AND メール設計書
  AND WebサービスAPI一覧
  AND 外部インタフェース一覧
  AND テーブル定義書
  AND 採番一覧
  AND ネットジョブフロー設計書
  AND メッセージ設計書?              // 多言語の追加分があるとき
  AND 外部I_F設計書_HTTP共通?
  AND List<取引設計セット>
  AND List<共通コンポーネント設計セット>
  AND List<電文設計セット>
  AND List<帳票設計セット>

data 取引設計セット =
  取引ID
  AND 取引名
  AND 処理方式
  AND システム機能設計書
  AND 単体テスト仕様書

data 共通コンポーネント設計セット =
  共通コンポーネントID
  AND 共通コンポーネント名
  AND 共通コンポーネント設計書
  AND 単体テスト_共通コンポーネント

data 電文設計セット =
  ファイルID_電文ID
  AND 形式情報
  AND 外部I_F設計書
data 形式情報 = データ形式_電文

data 帳票設計セット =
  帳票ID
  AND 帳票名
  AND 帳票設計書
